# GCP project — the only value konnekt needs at runtime
GCP_PROJECT_ID=<gcp-project-id>

# Authentication — no API keys or credential files here.
# konnekt authenticates to GCP Secret Manager via Workload Identity Federation.
# All LLM API keys live in GCP Secret Manager under kre8-konnekt-dev-{provider}.
#
# Cloud Run: attach kre8-sa-model-selector service account at deploy time.
# CI/CD:     configure WIF provider and set GOOGLE_APPLICATION_CREDENTIALS
#            to the generated WIF credential config file (not a key file).
