# ── Runtime config ────────────────────────────────────────────────────────────
# GCP project — the only value konnekt needs at runtime.
GCP_PROJECT_ID=<gcp-project-id>

# ── Authentication ─────────────────────────────────────────────────────────────
# No API keys or service account key files here.
# All LLM API keys live in GCP Secret Manager under kre8-konnekt-dev-{provider}.
# Auth to GCP SM is handled by Application Default Credentials (ADC).
#
# Local dev (uv):
#   Run once: gcloud auth application-default login
#   Credentials cached at ~/.config/gcloud/ — not a key file, expires automatically.
#   No env var needed after that.
#
# Docker / AWS ECS:
#   Set GOOGLE_APPLICATION_CREDENTIALS to a WIF credential config file.
#   This file is NOT a secret — it contains pool/provider config, no keys.
#   Generated by: gcloud iam workload-identity-pools create-cred-config ...
#   The AWS IAM role assumed by the ECS task is federated to kre8-sa-model-selector via WIF.
#   GOOGLE_APPLICATION_CREDENTIALS=/app/wif-config.json
#
# GKE:
#   Use GKE Workload Identity — map the k8s service account to kre8-sa-model-selector.
#   No env var needed. ADC picks up credentials from the metadata server.
#
# Cloud Run:
#   Attach kre8-sa-model-selector at deploy time (--service-account flag).
#   No env var needed. ADC picks up credentials from the metadata server.
